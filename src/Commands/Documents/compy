// compy.js – Create a Python file from raw code (no compression)
const fs = require('fs');
const path = require('path');

module.exports = {
    name: 'compy',
    alias: ['compresspy', 'minifypy'],
    desc: 'Create a Python file from raw code (reply to .py document or text message)',
    category: 'Tools',
    usage: '.compy <filename.py> (reply to a .py file or code text)  OR  .compy <filename.py> <code>',

    execute: async (sock, m, { args, reply }) => {
        // Get custom filename from user
        let customFileName = args[0]?.trim();
        if (customFileName && !customFileName.endsWith('.py')) customFileName += '.py';

        const quoted = m.quoted;
        let code = '';
        let sourceFileName = 'code.py';
        let isDocument = false;

        if (quoted) {
            const mtype = quoted.mtype || '';
            // Case: replied to a .py document
            if (mtype === 'documentMessage' && quoted.fileName?.endsWith('.py')) {
                isDocument = true;
                sourceFileName = quoted.fileName;
                try {
                    const buffer = await quoted.download();
                    if (!buffer || buffer.length === 0) return reply('✘ Failed to download file');
                    code = buffer.toString('utf8');
                } catch (err) {
                    return reply('✘ Failed to read document');
                }
            }
            // Case: replied to a text message
            else if (mtype === 'conversation' || mtype === 'extendedTextMessage') {
                code = quoted.text || quoted.body || '';
                if (!code.trim()) return reply('_✘ No Python code found in the replied message._');
            } else {
                return reply('_✘ Reply to a .py document or a text message containing Python code._');
            }
        } else {
            // Case: code provided directly in command
            if (!customFileName) return reply('_Provide a filename. Example: .compy script.py print("Hello")_');
            code = args.slice(1).join(' ').trim();
            if (!code) return reply('_No code provided after the filename._');
        }

        // Determine final filename
        let finalFileName = customFileName || (isDocument ? sourceFileName : '£.py');
        if (!finalFileName.endsWith('.py')) finalFileName += '.py';

        if (!code.trim()) return reply('_✘ No code to package._');

        try {
            await sock.sendMessage(m.chat, { react: { text: '📄', key: m.key } });
            await reply('`⚉ working...`');

            const tempDir = path.join(__dirname, '../../temp');
            if (!fs.existsSync(tempDir)) fs.mkdirSync(tempDir, { recursive: true });
            const outPath = path.join(tempDir, finalFileName);
            fs.writeFileSync(outPath, code, 'utf8');

            const stats = fs.statSync(outPath);
            const sizeKB = (stats.size / 1024).toFixed(2);

            await sock.sendMessage(m.chat, {
                document: fs.readFileSync(outPath),
                fileName: finalFileName,
                mimetype: 'text/x-python',   // or 'text/plain' if you prefer
                caption: `❏ *Python File Created*\n\n⎙ Filename: ${finalFileName}\n⎙ Size: ${stats.size} bytes (${sizeKB} KB)\n\n_⚉ CRYSNOVA Tools_`
            }, { quoted: m });

            fs.unlinkSync(outPath);
            await sock.sendMessage(m.chat, { react: { text: '🕸️', key: m.key } });

        } catch (err) {
            console.error('[COMPY ERROR]', err.message);
            reply(`✘ *Failed to create Python file*\n⎙ _${err.message}_`);
        }
    }
};
